APP_TITLE=Gains
APP_HOST=127.0.0.1
APP_PORT=8008
APP_SECRET=change-me-for-local-auth
APP_STATE_PATH=
KNOWLEDGE_REGISTRY_PATH=
APP_RELOAD=0
SKIP_PIP_INSTALL=0

# PostgreSQL runtime storage. When enabled with a valid DSN, core state moves off local JSON.
POSTGRES_ENABLED=false
POSTGRES_DSN=
POSTGRES_MIGRATIONS_PATH=

# Market data provider chain. Order matters.
MARKET_DATA_PROVIDER_ORDER=kite_mcp,jugaad_data,yfinance

# Zerodha Kite MCP setup. The app now talks to the hosted MCP endpoint directly.
KITE_MCP_ENABLED=true
KITE_MCP_MODE=hosted
KITE_MCP_URL=https://mcp.kite.trade/mcp
KITE_MCP_REPO_PATH=

# Legacy custom bridge options. Leave blank when using the built-in hosted integration.
KITE_MCP_BRIDGE_BASE_URL=
KITE_MCP_BRIDGE_API_KEY=

# Firebase / Google Auth
FIREBASE_ENABLED=false
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_ADMIN_CREDENTIALS_PATH=
AUTH_ALLOW_DEV_FALLBACK=true

# Firestore feedback sink
FEEDBACK_FIRESTORE_ENABLED=false
FEEDBACK_FIRESTORE_COLLECTION=feedback
FEEDBACK_FIRESTORE_PROJECT_ID=
FEEDBACK_FIRESTORE_CREDENTIALS_PATH=

# Turn this off if you want to skip chart snapshots.
TRADINGVIEW_ENABLED=true
TRADINGVIEW_DESKTOP_ENABLED=true

# Optional: the dashboard uses the cloned repo in the OpenAI folder by default.
# Override this if you move the repo somewhere else.
TRADINGVIEW_REPO_PATH=
TRADINGVIEW_DESKTOP_REPO_PATH=

# Required for live TradingView snapshots.
TRADINGVIEW_SESSION_ID=
TRADINGVIEW_SESSION_ID_SIGN=

# Optional scraper tuning.
TRADINGVIEW_HEADLESS=true
TRADINGVIEW_WINDOW_WIDTH=1400
TRADINGVIEW_WINDOW_HEIGHT=1400
TRADINGVIEW_CHART_PAGE_ID=
