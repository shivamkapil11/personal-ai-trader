APP_HOST=127.0.0.1
APP_PORT=8008

# Market data provider chain. Order matters.
MARKET_DATA_PROVIDER_ORDER=kite_mcp,jugaad_data,yfinance

# Zerodha Kite MCP setup.
KITE_MCP_ENABLED=true
KITE_MCP_MODE=hosted
KITE_MCP_URL=https://mcp.kite.trade/mcp
KITE_MCP_REPO_PATH=

# Turn this off if you want to skip chart snapshots.
TRADINGVIEW_ENABLED=true
TRADINGVIEW_DESKTOP_ENABLED=true

# Optional: the dashboard uses the cloned repo in the OpenAI folder by default.
# Override this if you move the repo somewhere else.
TRADINGVIEW_REPO_PATH=
TRADINGVIEW_DESKTOP_REPO_PATH=

# Required for live TradingView snapshots.
TRADINGVIEW_SESSION_ID=
TRADINGVIEW_SESSION_ID_SIGN=

# Optional scraper tuning.
TRADINGVIEW_HEADLESS=true
TRADINGVIEW_WINDOW_WIDTH=1400
TRADINGVIEW_WINDOW_HEIGHT=1400
TRADINGVIEW_CHART_PAGE_ID=
